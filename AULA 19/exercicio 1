import java.util.InputMismatchException;
import java.util.Scanner;

public class DivisaoTratada {
    public static void main(String[] args) {
        // Corrigido para System.in
        Scanner scanner = new Scanner(System.in); 
        
        while (true) {
            try {
                System.out.print("Digite o primeiro número inteiro: ");
                int num1 = scanner.nextInt();
                
                System.out.print("Digite o segundo número inteiro: ");
                int num2 = scanner.nextInt();
                
                // Realiza a divisão inteira
                int resultado = num1 / num2;
                
                System.out.println("Resultado da divisão: " + resultado);
                
                // Se o cálculo funcionou sem exceções, quebra o loop e encerra
                break; 
                
            } catch (InputMismatchException e) {
                System.out.println("Erro: Você precisa digitar um número inteiro válido! Tente novamente.\n");
                scanner.nextLine(); // Limpa o "lixo" do buffer para o loop funcionar
            } catch (ArithmeticException e) {
                System.out.println("Erro: Não é possível dividir um número por zero! Tente novamente.\n");
            }
        }
        
        scanner.close();
        System.out.println("Programa finalizado com sucesso.");
    }
    
}
