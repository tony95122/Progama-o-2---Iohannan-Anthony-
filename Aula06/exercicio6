import java.util.Scanner;

public class exercicio6 {
    public static void main(String[] args) {
        Scanner leitor = new Scanner(System.in);

        System.out.print("Digite uma frase: ");
        String frase = leitor.nextLine();

        System.out.print("Digite a palavra que deseja buscar: ");
        String palavra = leitor.nextLine();

        
        int posicao = frase.indexOf(palavra);

        if (posicao != -1) {
            System.out.println("Palavra encontrada! Ela inicia no índice: " + posicao);
        } else {
            System.out.println("A palavra não foi encontrada na frase (Retorno: -1).");
        }

        leitor.close();
    }
}
